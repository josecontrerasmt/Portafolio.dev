      { id: 1, logo: "bxl-html5", color: "text-[#e6532e]" },
      { id: 2, logo: "bxl-css3", color: "text-[#1ba3de]" },
      { id: 3, logo: "bxl-javascript", color: "text-[#ffde26]" },
    ],
    tituloProyecto: "Juego Rock-Paper-Scissors",
    descripcion:
      "Pequeño juego donde se tomó de inspiración un desafió de frontend mentor. Puedes elegir 2 maneras de jugar.",
    link: "https://josecontrerasmt.github.io/Game-Rock-Paper-Scissors/",
  },
  {
    id: 6,
    imagen: "/ProyectosIMGs/Challenge-ONE-Encriptador-de-Texto.png",
    herraminetas: [
      { id: 1, logo: "bxl-html5", color: "text-[#e6532e]" },
      { id: 2, logo: "bxl-css3", color: "text-[#1ba3de]" },
      { id: 3, logo: "bxl-javascript", color: "text-[#ffde26]" },
      { id: 4, logo: "bxl-tailwind-css", color: "text-[#35b8f0]" },
    ],
    tituloProyecto: "Challenge ONE - Encriptador de Texto",
    descripcion:
      "Desafió para un curso de Alura Latam donde se realizó un encriptador de texto.",
    link: "https://josecontrerasmt.github.io/Challenge-ONE-Encriptador-de-Texto/",
  },
